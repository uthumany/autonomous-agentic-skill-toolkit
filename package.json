{
  "name": "uthy-agentic-os",
  "version": "1.6.1",
  "description": "UTHY AGENTIC OS — Interactive CLI with cyberpunk HUD, chat interface, file upload, and 25 themes. The autonomous agentic operating system by uthuman & co.",
  "main": "src/index.js",
  "bin": {
    "uthy": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "shell": "node src/index.js shell",
    "test": "node --test tests/*.test.js",
    "test:flakiness": "node src/index.js test:flakiness https://example.com --iterations 3",
    "test:visual": "node src/index.js test:visual https://example.com --update-baseline",
    "generate:assertions": "node src/index.js generate:assertions https://example.com",
    "record:trace": "node src/index.js record:trace https://example.com -d 5",
    "provision": "node src/index.js provision ./tests"
  },
  "keywords": [
    "uthy",
    "agentic",
    "os",
    "cli",
    "interactive",
    "repl",
    "cyberpunk",
    "hud",
    "chat",
    "themes",
    "testing",
    "automation",
    "web",
    "mobile",
    "desktop",
    "flakiness",
    "parallel",
    "visual-regression",
    "session-replay",
    "provisioning",
    "test-oracle",
    "mcp",
    "file-upload"
  ],
  "author": "uthuman & co",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "playwright": "^1.44.0",
    "axios": "^1.6.0",
    "axe-core": "^4.9.1",
    "lighthouse": "^11.0.0",
    "chrome-launcher": "^1.0.0",
    "pngjs": "^7.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "prettier": "^3.2.0"
  }
}
