{
  "name": "autonomous-agentic-skill-toolkit",
  "version": "0.2.1",
  "description": "Autonomous Agentic Skill Toolkit — Interactive CLI for autonomous testing with flakiness detection, parallel execution, visual regression, AI test oracle, session replay, and environment provisioning.",
  "main": "src/index.js",
  "bin": {
    "aast": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "shell": "node src/index.js shell",
    "test": "node --test tests/*.test.js",
    "test:flakiness": "node src/index.js test:flakiness https://example.com --iterations 3",
    "test:visual": "node src/index.js test:visual https://example.com --update-baseline",
    "generate:assertions": "node src/index.js generate:assertions https://example.com",
    "record:trace": "node src/index.js record:trace https://example.com -d 5",
    "provision": "node src/index.js provision ./tests"
  },
  "keywords": [
    "agentic",
    "testing",
    "automation",
    "cli",
    "interactive",
    "web",
    "mobile",
    "desktop",
    "flakiness",
    "parallel",
    "visual-regression",
    "session-replay",
    "provisioning",
    "test-oracle",
    "mcp"
  ],
  "author": "uthuman & co",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "playwright": "^1.44.0",
    "axios": "^1.6.0",
    "axe-core": "^4.9.1",
    "lighthouse": "^11.0.0",
    "chrome-launcher": "^1.0.0",
    "pngjs": "^7.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "prettier": "^3.2.0"
  }
}
